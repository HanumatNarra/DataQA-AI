# Data-QA Application Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (KEEP SECRET! Server-side only)
# This bypasses Row Level Security - never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# OpenAI Configuration (Required)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
# Used for generating embeddings and natural language query processing

OPENAI_API_KEY=your_openai_api_key

# ============================================
# Application Configuration (Optional)
# ============================================

# Public URL of your application
# Used for CSRF origin validation
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
# Options: development, production, test
NODE_ENV=development

# ============================================
# Database Configuration (Optional)
# ============================================
# These are set automatically by Supabase but can be overridden

# Database connection string (if using direct database access)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# Feature Flags (Optional)
# ============================================

# Enable debug logging (development only)
# NEXT_PUBLIC_ENABLE_DEBUG=true

# Maximum file upload size in MB (default: 10)
# MAX_FILE_SIZE_MB=10

# Maximum charts to keep in history (default: 20)
# MAX_CHART_HISTORY=20

# ============================================
# Third-Party Services (Optional)
# ============================================

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics tracking ID
# NEXT_PUBLIC_GA_ID=

# Vercel Analytics (auto-detected on Vercel)
# VERCEL_ANALYTICS_ID=

# ============================================
# Rate Limiting (Optional)
# ============================================

# Redis URL for distributed rate limiting (production)
# REDIS_URL=

# Upstash Redis REST URL (alternative)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================
# Security (Optional)
# ============================================

# Secret for JWT signing (if implementing custom auth)
# JWT_SECRET=

# Session secret
# SESSION_SECRET=

# ============================================
# Notes
# ============================================
# 1. Create .env.local by copying this file
# 2. Fill in all required values
# 3. Never commit .env.local to git
# 4. Update .env.example when adding new variables
# 5. Restart dev server after changing .env values
